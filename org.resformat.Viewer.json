{
    "app-id": "org.resformat.Viewer",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
    "command": "res_viewer",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=host"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": { "CARGO_HOME": "/run/build/res_viewer/cargo" }
    },
    "modules": [
        {
            "name": "res_viewer",
            "buildsystem": "simple",
            "build-commands": [
                "cargo build --release -p res_viewer",
                "install -Dm755 target/release/res_viewer /app/bin/res_viewer",
                "install -Dm644 res_viewer/data/org.resformat.Viewer.desktop /app/share/applications/org.resformat.Viewer.desktop",
                "install -Dm644 res_viewer/data/org.resformat.Viewer.xml /app/share/mime/packages/org.resformat.Viewer.xml"
            ],
            "sources": [
                { "type": "dir", "path": "." },
                "cargo-sources.json"
            ]
        }
    ]
}
